{
  "name": "@headless-lms/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "build": "tsdown",
    "start": "node --env-file=../../.env dist/main.js",
    "gen:openapi": "tsx --env-file=../../.env scripts/gen-openapi.ts",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx --env-file=../../.env ../../packages/cli/src/index.ts seed",
    "db:migrate": "tsx --env-file=../../.env ../../packages/cli/src/index.ts migrate"
  },
  "dependencies": {
    "@headless-lms/plugin-slack": "workspace:*",
    "@headless-lms/server": "workspace:*",
    "@headless-lms/types": "workspace:*",
    "@headless-lms/utils": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsdown": "^0.22.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
