{
  "name": "@headless-lms/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/http/server.js",
  "scripts": {
    "dev": "tsx watch src/http/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/http/server.js",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs migrate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@headless-lms/shared-types": "workspace:*",
    "better-auth": "^1.6.22",
    "drizzle-orm": "^0.38.2",
    "fastify": "^5.2.0",
    "pg": "^8.13.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
