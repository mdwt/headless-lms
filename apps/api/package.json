{
  "name": "@headless-lms/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/http/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/http/server.ts",
    "build": "tsup",
    "start": "node --env-file=../../.env dist/http/server.js",
    "seed:admin": "tsx --env-file=../../.env scripts/seed-admin.ts",
    "gen:openapi": "tsx --env-file=../../.env scripts/gen-openapi.ts",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs migrate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@headless-lms/api-contract": "workspace:*",
    "@headless-lms/shared-types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "^1.6.22",
    "drizzle-orm": "^0.38.2",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^7.0.0",
    "minio": "^8.0.7",
    "pg": "^8.13.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
