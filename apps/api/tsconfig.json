{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    // Application package: nothing imports its declarations, so don't emit them.
    // Avoids TS2742 from third-party (better-auth/zod) inferred types under pnpm.
    "composite": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/**/*.ts"],
  "references": [{ "path": "../../packages/shared-types" }]
}
