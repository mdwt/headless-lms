{
  "name": "@headless-lms/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "drizzle"],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs migrate"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@headless-lms/api-contract": "workspace:*",
    "@headless-lms/types": "workspace:*",
    "@headless-lms/utils": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "^1.6.22",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^7.0.0",
    "ksuid": "^3.0.0",
    "minio": "^8.0.7",
    "pg": "^8.13.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsdown": "^0.22.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
