{
  "name": "@headless-lms/utils",
  "version": "0.0.0",
  "private": true,
  "description": "Runtime helpers for integration packages: adapt zod schemas to the @headless-lms/types integration contract.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@headless-lms/types": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "zod": "4.4.3"
  }
}
