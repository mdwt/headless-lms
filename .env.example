# API
PORT=8000
DATABASE_URL=postgres://postgres:postgres@localhost:8005/headless_lms

# Auth (better-auth)
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8000
# Comma-separated browser app origins allowed for CORS + as trusted origins.
# The admin dashboard (Next, 8001) and the student app (Next, 8002).
CLIENT_ORIGIN=http://localhost:8001,http://localhost:8002
# Login page shown to unauthenticated MCP OAuth clients (Better Auth mcp plugin).
MCP_LOGIN_PAGE=http://localhost:8001/login

# Stripe
STRIPE_SECRET_KEY=  # (not wired yet) placeholder for deferred billing

# Email
EMAIL_API_KEY=  # (not wired yet) placeholder for the email adapter

# Object storage (MinIO / S3-compatible) — uploads + content, served via
# presigned URLs. Defaults match the `minio` service in docker-compose.yml.
STORAGE_ENDPOINT=localhost
STORAGE_PORT=8006
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=headless-lms
STORAGE_REGION=us-east-1
# Presigned URL lifetimes, in seconds.
STORAGE_UPLOAD_EXPIRY=300
STORAGE_DOWNLOAD_EXPIRY=300

# Web (apps/web) — Vite needs VITE_ prefix to expose to the client.
VITE_API_URL=http://localhost:8000  # (not wired yet) placeholder, not read by any code

# Admin dashboard (apps/admin) — Next reads NEXT_PUBLIC_* from apps/admin/.env.local.
# This entry documents the value; the consumed copy lives in apps/admin/.env.local.
NEXT_PUBLIC_API_URL=http://localhost:8000
