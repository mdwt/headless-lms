# API
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/headless_lms

# Auth (better-auth)
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Origin of the web app, allowed for CORS + as a trusted origin.
CLIENT_ORIGIN=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=

# Email
EMAIL_API_KEY=

# Web (apps/web) — Vite needs VITE_ prefix to expose to the client.
VITE_API_URL=http://localhost:3000
