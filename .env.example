# API
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/headless_lms

# Auth (better-auth)
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated browser app origins allowed for CORS + as trusted origins.
# Includes the web app (Vite, 5173) and the admin dashboard (Next, 3001).
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=

# Email
EMAIL_API_KEY=

# Web (apps/web) — Vite needs VITE_ prefix to expose to the client.
VITE_API_URL=http://localhost:3000

# Admin dashboard (apps/admin) — Next reads NEXT_PUBLIC_* from apps/admin/.env.local.
# This entry documents the value; the consumed copy lives in apps/admin/.env.local.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Seed account created by `pnpm --filter @headless-lms/api seed:admin`.
SEED_ADMIN_EMAIL=mira@atelier.academy
SEED_ADMIN_PASSWORD=password123
SEED_ADMIN_NAME=Mira Okonkwo
SEED_ORG_NAME=Atelier Academy
SEED_ORG_SLUG=atelier
